# DATABASE_URL is built dynamically from MYSQL_* vars in app/config.py

# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=question

# Gmail SMTP (replace placeholders with your Gmail account details)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
APP_URL=
